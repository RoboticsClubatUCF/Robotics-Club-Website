generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum Season {
  summer
  spring
  fall
}

enum ImageSource {
  upload
  external
}

enum SponsorTier {
  PROCESSOR_PATRON
  CIRCUIT_SUPPORTER
  BOLT_BACKER
  ALUMINUM_ALLY
}

// ==================== PEOPLE ====================

// Login uses discordUserName + password. ucfEmail is the canonical contact.
model User {
  id              Int        @id @default(autoincrement())
  discordUserName String     @unique
  ucfEmail        String     @unique
  passwordHash    String
  authToken       String     @unique @default(uuid())

  firstName       String
  lastName        String?

  profileImage    Image?     @relation("UserProfileImage", fields: [profileImageId], references: [id])
  profileImageId  Int?

  role            Role       @relation(fields: [roleName], references: [name])
  roleName        String

  membershipExpDate  DateTime   @default(now())
  joinedAt           DateTime   @default(now())
  acknowledgedAt     DateTime?
  updatedAt          DateTime   @updatedAt

  survey             Survey?
  passwordResetToken PasswordResetToken?
  projectUsers       ProjectUser[]
}

// Used as both the global User role and the per-project ProjectUser role.
// Higher permissionLevel = more capability. Sort users by it for ordering.
model Role {
  name            String        @id
  permissionLevel Int           @default(0)
  discordRoleId   String?
  users           User[]
  projectUsers    ProjectUser[]
}

// 1-1 with User. Onboarding-only data — kept separate so the User row stays
// lean and the form fields can evolve without touching User.
model Survey {
  id                Int       @id @default(autoincrement())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            Int       @unique

  majors            String[]
  otherMajors       String?
  year              String?
  numberOfSemesters Int       @default(0)
  shirtSize         String?
  prevMember        Boolean   @default(false)
  allergies         String[]
  otherAllergies    String?
  concerns          String?
  discoveredThrough String[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int      @unique
}

// ==================== PROJECTS ====================

model Project {
  id            Int             @id @default(autoincrement())
  title         String
  description   String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  season        Season          @default(fall)
  year          Int
  docsLink      String?
  discordRoleId String?
  skills        String[]

  logo          Image?          @relation("ProjectLogo", fields: [imageId], references: [id])
  imageId       Int?

  users         ProjectUser[]
}

// Explicit M-M join between Project and User.
// roleId reuses the Role model for per-project titles like Project Lead,
// Team Lead, Engineer — sharing the same permissionLevel system as User.role.
model ProjectUser {
  projectId Int
  userId    Int
  roleName  String?
  joinedAt  DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role?    @relation(fields: [roleName], references: [name])

  @@id([projectId, userId])
}

// ==================== MEDIA ====================

// Unified image model. Referenced by User.profileImage, Project.logo,
// and Sponsor.logo. source disambiguates local upload vs. external URL.
model Image {
  id        Int         @id @default(autoincrement())
  source    ImageSource @default(upload)
  url       String
  alt       String?
  caption   String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  usersAsProfile User[]    @relation("UserProfileImage")
  projectsAsLogo Project[] @relation("ProjectLogo")
  sponsorsAsLogo Sponsor[] @relation("SponsorLogo")
}

// ==================== SPONSORSHIP ====================

// Absorbed WebSponsor + Receipt. endedAt is set when a sponsorship lapses.
model Sponsor {
  id          Int          @id @default(autoincrement())
  name        String
  tier        SponsorTier  @default(ALUMINUM_ALLY)
  websiteUrl  String?
  description String?
  amount      Float?
  startedAt   DateTime     @default(now())
  endedAt     DateTime?

  logo        Image?       @relation("SponsorLogo", fields: [imageId], references: [id])
  imageId     Int?
}

// ==================== CMS ====================

model SiteContent {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  type      String   @default("text")
  updatedAt DateTime @updatedAt
  updatedBy String?
}
