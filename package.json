{
	"name": "robotics-club-website",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"db": "docker compose up -d postgres_rccf",
		"services": "docker compose up -d",
		"prisma:inline": "node prisma/inline.cjs",
		"prisma:generate": "prisma generate && npm run prisma:inline",
		"prisma:migrate": "prisma migrate deploy && npm run prisma:inline",
		"prisma:migrate:dev": "prisma migrate dev && npm run prisma:inline",
		"studio": "npx prisma studio"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/bcrypt": "^6.0.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"prisma": "^7.8.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"bcrypt": "^6.0.0",
		"daisyui": "^5.5.19",
		"dotenv": "^17.4.2",
		"motion": "^12.38.0",
		"pg": "^8.20.0",
		"postmark": "^4.0.7",
		"stripe": "^22.1.1",
		"zod": "^4.4.3"
	}
}
